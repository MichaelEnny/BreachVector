# Optional. If omitted, BreachVector runs in demo mode with seeded showcase reports
# and in-memory scan history.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Optional but recommended with Supabase + Prisma for migrations and direct connections.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Optional. If omitted, BreachVector uses a built-in template report generator.
OPENAI_API_KEY="YOUR_OPENAI_API_KEY"
OPENAI_MODEL="gpt-5-mini"

# Optional for demo-only mode. Required to enable signed-in scans, private history,
# and account ownership.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Optional. Recommended in production if you want the internal worker route to be
# callable by Vercel Cron or another scheduler. The worker route accepts either
# JOB_WORKER_SECRET or CRON_SECRET.
JOB_WORKER_SECRET="YOUR_JOB_WORKER_SECRET"
CRON_SECRET="YOUR_CRON_SECRET"

# Optional. Helpful for metadata, share URLs, and deployment context.
APP_URL="http://localhost:3000"